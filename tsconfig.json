{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@weasel-js/core": ["../weasel/src/index.ts"],
      "@weasel-js/core/*": ["../weasel/src/import-shims/*.ts"]
    }
  },
  "include": ["src"]
}
